# Gmail 주소
GMAIL_ADDRESS=your@gmail.com

# Gmail 앱 비밀번호 16자리
# Google 계정 > 보안 > 2단계 인증 > 앱 비밀번호에서 생성합니다.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# 받을 주소입니다. 비워두면 GMAIL_ADDRESS로 보냅니다.
RECIPIENT_EMAIL=your@gmail.com

# 기본값은 한국어 Google 뉴스 주요뉴스입니다.
NEWS_LIMIT=5

# 선택: 특정 키워드 뉴스만 받고 싶을 때 사용합니다.
# NEWS_QUERY=경제 OR 기술

# 선택: 뉴스 중 하나를 골라 블로그 초안을 자동 작성합니다.
# BLOG_ENABLED=true
# BLOG_PICK_INDEX=1
# BLOG_DRAFT_DIR=blog_drafts

# 선택: 안정장치 설정입니다.
# RETRY_COUNT=3
# RETRY_DELAY_SECONDS=3
# REQUEST_TIMEOUT_SECONDS=10
# ERROR_EMAIL_ENABLED=true

# 선택: Gemini API로 콘텐츠 4종을 자동 작성합니다.
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-3.5-flash

# 선택: 직접 RSS 주소를 넣고 싶을 때 사용합니다.
# NEWS_FEED_URL=https://news.google.com/rss?hl=ko&gl=KR&ceid=KR:ko
